# .env.example
# Copia este archivo a .env y rellena los valores.
# .env está en .gitignore (nunca se commitean secretos).

# ── Neo4j ──────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_password_neo4j

# Puertos y advertised address del container (consumidos por docker-compose.yml).
# docker compose interpola estas variables al hacer `up`. Si falta una variable,
# FAIL-FAST: el container no levanta hasta que esté definida en .env.
NEO4J_BROWSER_PORT=7474
NEO4J_BOLT_PORT=7687
# Advertised addresses: qué host reporta Neo4j a los clientes.
# Dev local: "localhost:7687". Prod Orange Pi: "100.x.x.x:7687" (IP Tailscale).
# Escribí el string COMPLETO (host:port) — .env no hace interpolación anidada.
NEO4J_BOLT_ADVERTISED_ADDRESS=localhost:7687
NEO4J_HTTP_ADVERTISED_ADDRESS=localhost:7474
# Plugins: Neo4j parsea esto como JSON array literal.
# Formato EXACTO requerido: ["apoc"]  (comillas dobles, corchetes)
NEO4J_PLUGINS=["apoc"]

# ── LLM (OpenAI-compatible endpoint) ───────────────────────────────────
# Configurado por defecto para GROQ (remoto, rápido, sin bajar 40GB).
# Cambiá base_url + model_name si querés usar otro proveedor compatible con
# la API de OpenAI (OpenAI, Together, Ollama local, etc.).
#
#  ─ Groq (recomendado para este proyecto):
#       LLM_BASE_URL=https://api.groq.com/openai/v1
#       LLM_MODEL_NAME=llama-3.1-70b-versatile
#       LLM_API_KEY=gsk_... (pegá tu clave Groq)
#       Plan free: ~30 req/min → LLM_MAX_CONCURRENCY=3 está OK.
#
#  ─ Ollama local (alternativa, sin API key):
#       LLM_BASE_URL=http://localhost:11434/v1
#       LLM_MODEL_NAME=llama3:8b  (o llama3:70b, qwen2.5:14b, etc.)
#       LLM_API_KEY=              (dejar vacío/None)
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=llama-3.1-70b-versatile

# ── Procesamiento de PDF (chunking semántico TORO) ────────────────────
# El driver principal del chunking es el TOC del PDF (bookmarks jerárquicos).
# Estos valores son TECHO DE SEGURIDAD: si una sección excede max_chunk_size,
# se sub-divide por chars con chunk_overlap (conservando metadatos del padre).
PDF_MAX_CHUNK_SIZE=1500
PDF_CHUNK_OVERLAP=150
#  ⚠️ VALIDACIÓN EN SETTINGS: overlap DEBE ser estrictamente < max_chunk_size.
#  Si overlap >= max_chunk_size la app falla en arranque (Fail-Fast).

# ── Orquestación del caso de uso ───────────────────────────────────────
LLM_MAX_CONCURRENCY=3       # tope de llamadas LLM concurrentes (Semaphore)
PROCESSING_BATCH_SIZE=5     # tamaño de lote procesado por IndexBookUseCase

# ── Reintentos (tenacity, backoff EXPONENCIAL contra el LLM) ───────────
# wait = min(multiplier * 2^(intento-1), max)  →  1s, 2s, 4s, 8s ... hasta 30s
LLM_MAX_RETRIES=3
LLM_RETRY_WAIT_MULTIPLIER=1.0
LLM_RETRY_WAIT_MAX=30.0